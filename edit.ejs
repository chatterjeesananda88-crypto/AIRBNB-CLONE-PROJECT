<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
</head>
<body>
    <h3>Edit your Listing</h3>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <link rel="stylesheet" href="/css/style.css">

        <div class="mb-3">
            <lebal for="title" class="form-lebal">Title</lebal>
             <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control">
        </div>

        <div class="mb-3">
 
 <label for="description"></label>Description</label>
 <textarea id="description" name="listing[description]" 
         rows="5" column="5">
         <%= listing.description%></textarea> 
 </div>
<div class="mb-3">
       
         <input name="listing[image]" value="<%= listing.image %>" type="text"class="form-control"/>
         </div>
         <div class="mb-3">
         <input name="listing[price]" value="<%= listing.price %>" type="number" class="form-control"/>
         </div>
        <div class="mb-3">
         <input name="listing[country]" value="<%= listing.country %>" type="text" class="form-control"/>
         </div>

         <div class="mb-3">
         
         <input name="listing[location]" value="<%= listing.location %>"  type="text" class="form-control"/>
         </div>
         <br/><br/>
         <button class="btn btn-dark edit-btn">Edit</button>
         
         
    </form>
    
</body>
</html>